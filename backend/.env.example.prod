# Server Configuration
# PORT is automatically set by Render - don't set this manually
NODE_ENV=production

# Database Configuration (Supabase)
# Pooled connection (for app usage)
DATABASE_URL="postgresql://postgres.q:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres.:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# JWT Configuration
# Generate a secure random string at least 32 characters long
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# CORS Configuration
# Replace with your actual frontend URL on Render
CORS_ORIGINS=https://your-frontend-url.onrender.com
